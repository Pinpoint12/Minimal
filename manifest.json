{
	"manifest_version": 3,
	"name": "minimal",
	"version": "1.3.0",

	"default_locale": "en",

	"description": "A browser extension that simplifies popular websites by removing distracting elements and focusing on core content",

	"icons": {
		"48": "icons/icon.png",
		"96": "icons/icon@2x.png",
		"128": "icons/icon128.png",
		"192": "icons/icon@4x.png"
	},

	"author": "AUPYA with edits by @pinpoint24",
	"homepage_url": "https://minimal.aupya.org",

	"background": {
		"service_worker": "main.js"
	},

	"content_scripts": [
		{
			"matches": ["*://*.youtube.com/*"],
			"css": ["styles/youtube.css"],
			"js": ["scripts/youtube.js", "scripts/blocker-tracker.js"],
			"run_at": "document_start"
		},
		{
			"matches": ["*://*.facebook.com/*"],
			"css": ["styles/facebook.css"],
			"js": ["scripts/facebook.js", "scripts/blocker-tracker.js"]
		},
		{
			"matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
			"css": ["styles/twitter.css"],
			"js": ["scripts/twitter.js", "scripts/blocker-tracker.js"]
		},
		{
			"matches": [
				"*://*.amazon.com/*",
				"*://*.amazon.ca/*",
				"*://*.amazon.co.uk/*",
				"*://*.amazon.de/*",
				"*://*.amazon.fr/*",
				"*://*.amazon.it/*",
				"*://*.amazon.es/*",
				"*://*.amazon.co.jp/*",
				"*://*.amazon.cn/*",
				"*://*.amazon.in/*",
				"*://*.amazon.com.br/*",
				"*://*.amazon.com.mx/*",
				"*://*.amazon.com.au/*",
				"*://*.amazon.nl/*"
			],
			"css": ["styles/amazon.css"],
			"js": ["scripts/blocker-tracker.js"]
		},
		{
			"matches": [
				"*://*.google.com/*",
				"*://*.google.co.uk/*",
				"*://*.google.ca/*",
				"*://*.google.de/*",
				"*://*.google.fr/*",
				"*://*.google.es/*",
				"*://*.google.it/*",
				"*://*.google.nl/*",
				"*://*.google.com.au/*",
				"*://*.google.co.jp/*",
				"*://*.google.co.in/*",
				"*://*.google.com.br/*",
				"*://*.google.com.mx/*",
				"*://*.google.ru/*",
				"*://*.google.cn/*"
			],
			"css": ["styles/google.css"],
			"js": ["scripts/blocker-tracker.js"]
		},
		{
			"matches": ["*://*.yahoo.com/*"],
			"css": ["styles/yahoo.css"],
			"js": ["scripts/blocker-tracker.js"]
		},
		{
			"matches": ["*://*.netflix.com/*"],
			"css": ["styles/netflix.css"],
			"js": ["scripts/netflix.js", "scripts/blocker-tracker.js"]
		},
		{
			"matches": [
				"*://*.reddit.com/*",
				"*://reddit.com/*"
			],
			"css": ["styles/reddit.css"],
			"js": ["scripts/reddit.js", "scripts/blocker-tracker.js"]
		}
	],

	"permissions": [
		"storage",
		"scripting"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"action": {
		"default_icon": {
			"19": "icons/pageAction.png",
			"38": "icons/icon@2x.png"
		},
		"default_title": "__MSG_pageActionDefaultTitle__",
		"default_popup": "pages/badgePopup.html"
	}
}
